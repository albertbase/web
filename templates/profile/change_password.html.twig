{% extends 'base_admin.html.twig' %}

{% block body %}

{# <link rel="stylesheet" href="{{ asset('css/change_password.css') }}"> #}

<style>
    /* Page entrance animation */
    .fade-slide {
        animation: fadeSlide .35s ease forwards;
        opacity: 0;
        transform: translateY(10px);
    }
    @keyframes fadeSlide {
        to { opacity: 1; transform: translateY(0); }
    }

    /* Card hover micro-interaction */
    .sweetoria-card {
        transition: transform .25s ease, box-shadow .25s ease;
        border-radius: 14px;
    }
    .sweetoria-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
    }

    /* Floating label container */
    .floating-group {
        position: relative;
        margin-bottom: 1.8rem;
    }

    /* Input styling */
    .floating-input {
        width: 100%;
        padding: 14px 12px 10px;
        border: 1px solid #ced4da;
        border-radius: 8px;
        font-size: 1rem;
        transition: all .25s ease;
        background: white;
    }

    .floating-input:focus {
        border-color: #4e73df;
        box-shadow: 0 0 0 0.15rem rgba(78,115,223,0.25);
        outline: none;
    }

    /* Floating label */
    .floating-label {
        position: absolute;
        top: 50%;
        left: 12px;
        transform: translateY(-50%);
        font-size: 1rem;
        color: #6c757d;
        pointer-events: none;
        transition: all .25s ease;
        background: white;
        padding: 0 4px;
    }

    /* When input has value OR is focused */
    .floating-input:focus + .floating-label,
    .floating-input:not(:placeholder-shown) + .floating-label {
        top: -8px;
        font-size: 0.75rem;
        color: #4e73df;
    }

    /* Button animation */
    .sweetoria-btn {
        transition: all .25s ease;
        border-radius: 8px;
    }
    .sweetoria-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 18px rgba(78,115,223,0.3);
    }
</style>

<div class="sweetoria-container fade-slide">
    <div class="sweetoria-card shadow-lg p-4" style="max-width: 520px; margin: auto;">

        <h1 class="sweetoria-title text-center mb-3">🔒 Change Password</h1>
        <p class="text-muted text-center mb-4">Keep your account secure by updating your password</p>

        {{ form_start(form, {
            action: path('user_change_password'),
            method: 'POST',
            attr: { class: 'sweetoria-form' }
        }) }}

            {{ form_errors(form) }}

            <!-- Current Password -->
            <div class="floating-group">
                {{ form_widget(form.currentPassword, {
                    attr: {
                        class: 'floating-input',
                        placeholder: ' '
                    }
                }) }}
                <label class="floating-label">Current Password</label>
                {{ form_errors(form.currentPassword) }}
            </div>

            <!-- New Password -->
            <div class="floating-group">
                {{ form_widget(form.newPassword.first, {
                    attr: {
                        class: 'floating-input',
                        placeholder: ' '
                    }
                }) }}
                <label class="floating-label">New Password</label>
                {{ form_errors(form.newPassword.first) }}
            </div>

            <!-- Confirm New Password -->
            <div class="floating-group">
                {{ form_widget(form.newPassword.second, {
                    attr: {
                        class: 'floating-input',
                        placeholder: ' '
                    }
                }) }}
                <label class="floating-label">Confirm New Password</label>
                {{ form_errors(form.newPassword.second) }}
            </div>

            {{ form_widget(form._token) }}

            <button class="btn sweetoria-btn w-100 mt-2">Update Password</button>

        {{ form_end(form, { render_rest: false }) }}
    </div>
</div>

{% endblock %}
