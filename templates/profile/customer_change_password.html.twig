{% extends 'base.html.twig' %}

{% block title %}Change Password{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/user_profile.css') }}">
{% endblock %}

{% block body %}
<section class="account-profile-page">
    <header class="account-hero account-hero-compact">
        <p class="account-kicker">Security</p>
        <h1 class="account-title">Change Password</h1>
        <p class="account-subtitle">Password must be at least 8 characters and include an uppercase letter, a lowercase letter, a number, and a special character.</p>
    </header>

    <article class="account-form-card">
        {{ form_start(form, {
            action: path('customer_change_password'),
            method: 'POST',
            attr: { class: 'account-form' }
        }) }}

        {{ form_errors(form) }}

        <div class="account-field-group">
            {{ form_label(form.currentPassword, 'Current Password', { label_attr: { class: 'account-field-label' } }) }}
            {{ form_widget(form.currentPassword, { attr: { class: 'account-field-input', placeholder: 'Enter current password' } }) }}
            {{ form_errors(form.currentPassword) }}
        </div>

        <div class="account-field-group">
            {{ form_label(form.newPassword.first, 'New Password', { label_attr: { class: 'account-field-label' } }) }}
            {{ form_widget(form.newPassword.first, { attr: { class: 'account-field-input', placeholder: 'At least 8 characters' } }) }}
            {{ form_errors(form.newPassword.first) }}
        </div>

        <div class="account-field-group">
            {{ form_label(form.newPassword.second, 'Confirm New Password', { label_attr: { class: 'account-field-label' } }) }}
            {{ form_widget(form.newPassword.second, { attr: { class: 'account-field-input', placeholder: 'Type new password again' } }) }}
            {{ form_errors(form.newPassword.second) }}
        </div>

        <div class="account-form-actions">
            <a href="{{ path('customer_profile') }}" class="account-btn account-btn-outline">Back to Profile</a>
            <button type="submit" class="account-btn account-btn-primary">Update Password</button>
        </div>

        {{ form_end(form) }}
    </article>
</section>
{% endblock %}
