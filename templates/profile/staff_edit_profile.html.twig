{% extends 'base_admin.html.twig' %}

{% block title %}Edit Staff Profile{% endblock %}

{% block body %}
<div class="staff-profile-page">
    <div class="panel-card mb-4">
        <p class="panel-kicker mb-2">Team Account</p>
        <h1 class="panel-title mb-1">Edit Staff Profile</h1>
        <p class="page-subtitle mb-0">Update your workspace display name and login username.</p>
    </div>

    <div class="panel-card">
        {{ form_start(form, { attr: { class: 'staff-profile-form' } }) }}
        {{ form_errors(form) }}

        <div class="mb-3">
            {{ form_label(form.name, 'Display Name') }}
            {{ form_widget(form.name, { attr: { class: 'form-control', placeholder: 'How your name appears in the admin workspace' } }) }}
            {{ form_errors(form.name) }}
        </div>

        <div class="mb-4">
            {{ form_label(form.username, 'Username') }}
            {{ form_widget(form.username, { attr: { class: 'form-control', placeholder: 'Your login username' } }) }}
            {{ form_errors(form.username) }}
        </div>

        <div class="d-flex flex-wrap gap-2">
            <a href="{{ path('staff_profile') }}" class="btn btn-outline-secondary">Back to Profile</a>
            <button type="submit" class="btn btn-primary">Save Changes</button>
        </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
