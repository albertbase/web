{% extends 'base_admin.html.twig' %}

{% block title %}Change Staff Password{% endblock %}

{% block body %}
<div class="staff-profile-page">
    <div class="panel-card mb-4">
        <p class="panel-kicker mb-2">Security</p>
        <h1 class="panel-title mb-1">Change Password</h1>
        <p class="page-subtitle mb-0">Password must be at least 8 characters and include an uppercase letter, a lowercase letter, a number, and a special character.</p>
    </div>

    <div class="panel-card">
        {{ form_start(form, {
            action: path('staff_change_password'),
            method: 'POST',
            attr: { class: 'staff-profile-form' }
        }) }}
        {{ form_errors(form) }}

        <div class="mb-3">
            {{ form_label(form.currentPassword, 'Current Password') }}
            {{ form_widget(form.currentPassword, { attr: { class: 'form-control', placeholder: 'Enter current password' } }) }}
            {{ form_errors(form.currentPassword) }}
        </div>

        <div class="mb-3">
            {{ form_label(form.newPassword.first, 'New Password') }}
            {{ form_widget(form.newPassword.first, { attr: { class: 'form-control', placeholder: 'At least 8 characters' } }) }}
            {{ form_errors(form.newPassword.first) }}
        </div>

        <div class="mb-4">
            {{ form_label(form.newPassword.second, 'Confirm New Password') }}
            {{ form_widget(form.newPassword.second, { attr: { class: 'form-control', placeholder: 'Type new password again' } }) }}
            {{ form_errors(form.newPassword.second) }}
        </div>

        <div class="d-flex flex-wrap gap-2">
            <a href="{{ path('staff_profile') }}" class="btn btn-outline-secondary">Back to Profile</a>
            <button type="submit" class="btn btn-primary">Update Password</button>
        </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
