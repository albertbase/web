<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Sweetoria Mobile</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Fraunces:opsz,wght@9..144,600;9..144,700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #f8f2ea;
            --panel: #fffdf9;
            --ink: #2f241f;
            --muted: #826e61;
            --accent: #b65a3c;
            --accent-dark: #94412a;
            --line: #eadfce;
            --ok: #287a5f;
            --warn: #b8362e;
            --shadow: 0 12px 32px rgba(43, 29, 20, 0.15);
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: 'DM Sans', sans-serif;
            color: var(--ink);
            background: radial-gradient(circle at 10% 0%, #ffe9c8 0%, transparent 45%),
                        radial-gradient(circle at 90% 85%, #f7cfb6 0%, transparent 42%),
                        var(--bg);
            display: grid;
            place-items: center;
            padding: 12px;
        }

        .mobile-shell {
            width: min(460px, 100%);
            min-height: 92vh;
            background: var(--panel);
            border: 1px solid #f0e8db;
            border-radius: 24px;
            box-shadow: var(--shadow);
            display: grid;
            grid-template-rows: auto 1fr auto;
            overflow: hidden;
            animation: rise-in 350ms ease-out;
        }

        .topbar {
            padding: 18px 18px 12px;
            border-bottom: 1px solid var(--line);
            background: linear-gradient(180deg, #fff8f2 0%, #fffcf8 100%);
        }

        .title-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
        }

        .title {
            margin: 0;
            font-family: 'Fraunces', serif;
            font-size: 1.3rem;
            letter-spacing: 0.2px;
        }

        .subtitle {
            margin: 6px 0 0;
            color: var(--muted);
            font-size: 0.88rem;
        }

        .logout-link {
            color: var(--accent-dark);
            font-size: 0.85rem;
            text-decoration: none;
            border: 1px solid #efdfd3;
            border-radius: 999px;
            padding: 6px 10px;
            background: #fff;
        }

        .content {
            padding: 14px;
            overflow: auto;
        }

        .view {
            display: none;
            animation: fade-up 220ms ease-out;
        }

        .view.active {
            display: block;
        }

        .card {
            border: 1px solid var(--line);
            border-radius: 14px;
            background: #fff;
            padding: 12px;
        }

        .search-wrap {
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 8px;
            margin-bottom: 12px;
        }

        .search-input,
        .chip-select {
            border: 1px solid #e7d8c6;
            border-radius: 10px;
            padding: 10px 11px;
            font: inherit;
            color: var(--ink);
            background: #fff;
        }

        .chip-row {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-bottom: 12px;
        }

        .chip {
            border: 1px solid #e8d8cb;
            background: #fff8ef;
            color: #6d4d3b;
            border-radius: 999px;
            padding: 5px 11px;
            font-size: 0.78rem;
            cursor: pointer;
        }

        .chip.active {
            background: var(--accent);
            border-color: var(--accent);
            color: #fff;
        }

        .product-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 10px;
        }

        .product-card {
            border: 1px solid #eadfd1;
            border-radius: 12px;
            padding: 10px;
            display: grid;
            grid-template-columns: 70px 1fr auto;
            gap: 10px;
            align-items: center;
        }

        .product-thumb {
            width: 70px;
            height: 70px;
            border-radius: 10px;
            object-fit: cover;
            border: 1px solid #e6d7ca;
            background: #f4ece2;
        }

        .product-name {
            margin: 0 0 4px;
            font-size: 0.95rem;
            font-weight: 700;
        }

        .product-meta {
            margin: 0;
            font-size: 0.8rem;
            color: var(--muted);
        }

        .price {
            margin-top: 6px;
            font-weight: 700;
            color: var(--accent-dark);
            font-size: 0.9rem;
        }

        .btn,
        .btn-soft {
            border: 0;
            border-radius: 10px;
            font: inherit;
            padding: 8px 11px;
            cursor: pointer;
        }

        .btn {
            background: var(--accent);
            color: #fff;
            font-weight: 600;
        }

        .btn:hover {
            background: var(--accent-dark);
        }

        .btn:disabled {
            background: #d8b8a9;
            cursor: not-allowed;
        }

        .btn-soft {
            background: #f5ece2;
            color: #5f4b3e;
            border: 1px solid #eadfce;
        }

        .list {
            display: grid;
            gap: 8px;
        }

        .cart-item,
        .order-item {
            border: 1px solid #ece2d3;
            border-radius: 12px;
            padding: 10px;
            background: #fff;
            display: grid;
            gap: 7px;
        }

        .row-between {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 8px;
        }

        .qty-row {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .qty-btn {
            width: 28px;
            height: 28px;
            border-radius: 8px;
            border: 1px solid #e4d7c8;
            background: #fffaf5;
            color: #664c3d;
            cursor: pointer;
        }

        .summary {
            margin-top: 10px;
            border-top: 1px dashed #dbcbb8;
            padding-top: 10px;
            display: grid;
            gap: 8px;
        }

        .form-grid {
            display: grid;
            gap: 8px;
        }

        .field {
            border: 1px solid #e3d7c7;
            border-radius: 10px;
            padding: 10px 11px;
            font: inherit;
        }

        .muted {
            color: var(--muted);
            font-size: 0.85rem;
        }

        .empty {
            border: 1px dashed #dfd1c2;
            background: #fffaf5;
            border-radius: 12px;
            padding: 16px;
            text-align: center;
            color: var(--muted);
            font-size: 0.9rem;
        }

        .tabbar {
            border-top: 1px solid var(--line);
            background: #fffaf3;
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 4px;
            padding: 8px;
        }

        .tab-btn {
            border: 0;
            border-radius: 10px;
            padding: 9px 6px;
            font: inherit;
            font-size: 0.82rem;
            color: #694f41;
            background: transparent;
            cursor: pointer;
        }

        .tab-btn.active {
            background: #f4e4d8;
            color: var(--accent-dark);
            font-weight: 700;
        }

        .toast {
            position: fixed;
            left: 50%;
            bottom: 16px;
            transform: translate(-50%, 20px);
            padding: 10px 14px;
            border-radius: 10px;
            color: #fff;
            background: var(--ok);
            font-size: 0.85rem;
            opacity: 0;
            pointer-events: none;
            transition: all 200ms ease;
        }

        .toast.error {
            background: var(--warn);
        }

        .toast.show {
            opacity: 1;
            transform: translate(-50%, 0);
        }

        @keyframes rise-in {
            from {
                opacity: 0;
                transform: translateY(14px) scale(0.99);
            }
            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        @keyframes fade-up {
            from {
                opacity: 0;
                transform: translateY(8px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @media (max-height: 730px) {
            .mobile-shell {
                min-height: 96vh;
            }
        }
    </style>
</head>
<body>
<div class="mobile-shell">
    <header class="topbar">
        <div class="title-row">
            <h1 class="title">Sweetoria Mobile</h1>
            <form method="post" action="{{ path('app_logout') }}" class="m-0 d-inline">
              <button type="submit" class="logout-link border-0 bg-transparent p-0">Log Out</button>
            </form>
        </div>
        <p class="subtitle">Customer order flow powered by Customer API</p>
    </header>

    <main class="content">
        <section class="view active" data-view="products">
            <div class="search-wrap">
                <input id="searchInput" class="search-input" type="search" placeholder="Search products">
                <button id="refreshProducts" class="btn-soft" type="button">Refresh</button>
            </div>
            <div id="categoryChips" class="chip-row"></div>
            <div id="productsList" class="product-grid"></div>
        </section>

        <section class="view" data-view="cart">
            <div id="cartList" class="list"></div>
            <div class="card summary">
                <div class="row-between">
                    <strong>Total</strong>
                    <strong id="cartTotal">PHP 0.00</strong>
                </div>
                <div class="form-grid">
                    <input id="customerName" class="field" type="text" placeholder="Customer name">
                    <input id="customerPhone" class="field" type="text" placeholder="Phone number (optional)">
                </div>
                <button id="checkoutBtn" class="btn" type="button">Place order</button>
                <p class="muted">Orders are validated against live stock before checkout.</p>
            </div>
        </section>

        <section class="view" data-view="orders">
            <div id="ordersList" class="list"></div>
        </section>

        <section class="view" data-view="profile">
            <div id="profileCard" class="card"></div>
        </section>
    </main>

    <nav class="tabbar">
        <button class="tab-btn active" data-tab="products" type="button">Products</button>
        <button class="tab-btn" data-tab="cart" type="button">Cart</button>
        <button class="tab-btn" data-tab="orders" type="button">Orders</button>
        <button class="tab-btn" data-tab="profile" type="button">Profile</button>
    </nav>
</div>

<div id="toast" class="toast"></div>

<script>
(() => {
    const apiToken = '{{ apiToken|e('js') }}';
    const cartStorageKey = 'sweetoria_mobile_cart_v1';

    const state = {
        categories: [],
        products: [],
        filteredProducts: [],
        orders: [],
        me: null,
        selectedCategory: '',
        cart: loadCart(),
        activeTab: 'products',
    };

    const views = document.querySelectorAll('.view');
    const tabButtons = document.querySelectorAll('.tab-btn');
    const searchInput = document.getElementById('searchInput');
    const categoryChips = document.getElementById('categoryChips');
    const productsList = document.getElementById('productsList');
    const cartList = document.getElementById('cartList');
    const cartTotal = document.getElementById('cartTotal');
    const customerNameField = document.getElementById('customerName');
    const customerPhoneField = document.getElementById('customerPhone');
    const checkoutBtn = document.getElementById('checkoutBtn');
    const ordersList = document.getElementById('ordersList');
    const profileCard = document.getElementById('profileCard');
    const refreshProductsBtn = document.getElementById('refreshProducts');
    const toast = document.getElementById('toast');

    tabButtons.forEach((button) => {
        button.addEventListener('click', () => switchTab(button.dataset.tab || 'products'));
    });

    searchInput.addEventListener('input', applyFilters);
    refreshProductsBtn.addEventListener('click', refreshCatalog);
    checkoutBtn.addEventListener('click', placeOrder);

    loadInitialData();

    function switchTab(tab) {
        state.activeTab = tab;
        tabButtons.forEach((button) => button.classList.toggle('active', button.dataset.tab === tab));
        views.forEach((view) => view.classList.toggle('active', view.dataset.view === tab));
    }

    async function loadInitialData() {
        try {
            const [categoryData, productData, orderData, meData] = await Promise.all([
                apiRequest('/api/customer/categories'),
                apiRequest('/api/customer/products'),
                apiRequest('/api/customer/orders'),
                apiRequest('/api/me'),
            ]);

            state.categories = categoryData.categories || [];
            state.products = productData.products || [];
            state.filteredProducts = [...state.products];
            state.orders = orderData.orders || [];
            state.me = meData.user || null;

            customerNameField.value = state.me?.name || state.me?.username || '';

            renderCategories();
            renderProducts();
            renderCart();
            renderOrders();
            renderProfile();
        } catch (error) {
            showToast(error.message || 'Unable to load customer data.', true);
        }
    }

    async function refreshCatalog() {
        try {
            const productData = await apiRequest('/api/customer/products');
            state.products = productData.products || [];
            applyFilters();
            showToast('Catalog refreshed.');
        } catch (error) {
            showToast(error.message || 'Unable to refresh products.', true);
        }
    }

    function renderCategories() {
        const categories = [{ id: 0, name: 'All' }, ...state.categories];
        categoryChips.innerHTML = categories.map((category) => {
            const selected = state.selectedCategory === category.name || (category.name === 'All' && state.selectedCategory === '');
            return `
                <button class="chip ${selected ? 'active' : ''}" data-category="${escapeHtml(category.name)}" type="button">
                    ${escapeHtml(category.name)}
                </button>
            `;
        }).join('');

        categoryChips.querySelectorAll('.chip').forEach((chip) => {
            chip.addEventListener('click', () => {
                const value = chip.dataset.category || '';
                state.selectedCategory = value === 'All' ? '' : value;
                renderCategories();
                applyFilters();
            });
        });
    }

    function applyFilters() {
        const term = searchInput.value.trim().toLowerCase();
        const selectedCategory = state.selectedCategory;

        state.filteredProducts = state.products.filter((product) => {
            const matchesSearch = term === ''
                || (product.name || '').toLowerCase().includes(term)
                || (product.description || '').toLowerCase().includes(term);
            const matchesCategory = selectedCategory === '' || (product.category || '') === selectedCategory;
            return matchesSearch && matchesCategory;
        });

        renderProducts();
    }

    function renderProducts() {
        if (state.filteredProducts.length === 0) {
            productsList.innerHTML = '<div class="empty">No products matched your filter.</div>';
            return;
        }

        productsList.innerHTML = state.filteredProducts.map((product) => {
            const stock = Number(product.stock || 0);
            const disabled = stock <= 0 ? 'disabled' : '';
            return `
                <article class="product-card">
                    <img class="product-thumb" src="${escapeAttr(product.imageUrl || '/image/logo.png')}" alt="${escapeAttr(product.name || 'Product image')}">
                    <div>
                        <p class="product-name">${escapeHtml(product.name || 'Untitled')}</p>
                        <p class="product-meta">${escapeHtml(product.category || 'Uncategorized')} | Stock: ${stock}</p>
                        <p class="price">${formatCurrency(product.price || 0)}</p>
                    </div>
                    <button class="btn add-btn" data-product-id="${Number(product.id)}" ${disabled}>Add</button>
                </article>
            `;
        }).join('');

        productsList.querySelectorAll('.add-btn').forEach((button) => {
            button.addEventListener('click', () => {
                const id = Number(button.dataset.productId);
                addToCart(id);
            });
        });
    }

    function addToCart(productId) {
        const product = state.products.find((item) => Number(item.id) === productId);
        if (!product) {
            showToast('Product no longer available.', true);
            return;
        }

        const stock = Number(product.stock || 0);
        const entry = state.cart.find((item) => Number(item.productId) === productId);
        const currentQty = entry ? Number(entry.quantity) : 0;

        if (currentQty >= stock) {
            showToast('Stock limit reached for this product.', true);
            return;
        }

        if (entry) {
            entry.quantity = currentQty + 1;
        } else {
            state.cart.push({ productId, quantity: 1 });
        }

        persistCart();
        renderCart();
        showToast('Added to cart.');
    }

    function renderCart() {
        if (state.cart.length === 0) {
            cartList.innerHTML = '<div class="empty">Your cart is empty.</div>';
            cartTotal.textContent = formatCurrency(0);
            return;
        }

        let total = 0;
        cartList.innerHTML = state.cart.map((entry) => {
            const product = state.products.find((item) => Number(item.id) === Number(entry.productId));
            if (!product) {
                return '';
            }

            const quantity = Number(entry.quantity);
            const price = Number(product.price || 0);
            const subtotal = quantity * price;
            total += subtotal;

            return `
                <article class="cart-item">
                    <div class="row-between">
                        <strong>${escapeHtml(product.name || 'Untitled')}</strong>
                        <span>${formatCurrency(subtotal)}</span>
                    </div>
                    <div class="row-between">
                        <span class="muted">${escapeHtml(product.category || 'Uncategorized')}</span>
                        <div class="qty-row">
                            <button class="qty-btn" data-act="decrease" data-id="${Number(entry.productId)}" type="button">-</button>
                            <strong>${quantity}</strong>
                            <button class="qty-btn" data-act="increase" data-id="${Number(entry.productId)}" type="button">+</button>
                            <button class="qty-btn" data-act="remove" data-id="${Number(entry.productId)}" type="button">x</button>
                        </div>
                    </div>
                </article>
            `;
        }).join('');

        cartTotal.textContent = formatCurrency(total);

        cartList.querySelectorAll('.qty-btn').forEach((button) => {
            button.addEventListener('click', () => {
                const action = button.dataset.act || '';
                const id = Number(button.dataset.id || 0);
                updateCartItem(action, id);
            });
        });
    }

    function updateCartItem(action, productId) {
        const entry = state.cart.find((item) => Number(item.productId) === productId);
        if (!entry) {
            return;
        }

        if (action === 'remove') {
            state.cart = state.cart.filter((item) => Number(item.productId) !== productId);
            persistCart();
            renderCart();
            return;
        }

        if (action === 'increase') {
            const product = state.products.find((item) => Number(item.id) === productId);
            if (!product) {
                showToast('Product no longer available.', true);
                return;
            }

            if (entry.quantity >= Number(product.stock || 0)) {
                showToast('Stock limit reached for this product.', true);
                return;
            }

            entry.quantity += 1;
        }

        if (action === 'decrease') {
            entry.quantity -= 1;
            if (entry.quantity <= 0) {
                state.cart = state.cart.filter((item) => Number(item.productId) !== productId);
            }
        }

        persistCart();
        renderCart();
    }

    async function placeOrder() {
        if (state.cart.length === 0) {
            showToast('Cart is empty.', true);
            return;
        }

        checkoutBtn.disabled = true;
        checkoutBtn.textContent = 'Placing order...';

        try {
            const payload = {
                customerName: customerNameField.value.trim(),
                customerPhone: customerPhoneField.value.trim(),
                items: state.cart.map((entry) => ({
                    productId: Number(entry.productId),
                    quantity: Number(entry.quantity),
                })),
            };

            const responseData = await apiRequest('/api/customer/orders', {
                method: 'POST',
                body: JSON.stringify(payload),
            });

            state.cart = [];
            persistCart();
            renderCart();
            customerPhoneField.value = '';

            const productsData = await apiRequest('/api/customer/products');
            state.products = productsData.products || [];
            applyFilters();

            const ordersData = await apiRequest('/api/customer/orders');
            state.orders = ordersData.orders || [];
            renderOrders();

            showToast(`Order #${responseData.order?.id || ''} placed successfully.`);
            switchTab('orders');
        } catch (error) {
            showToast(error.message || 'Checkout failed.', true);
        } finally {
            checkoutBtn.disabled = false;
            checkoutBtn.textContent = 'Place order';
        }
    }

    function renderOrders() {
        if (state.orders.length === 0) {
            ordersList.innerHTML = '<div class="empty">No orders yet.</div>';
            return;
        }

        ordersList.innerHTML = state.orders.map((order) => {
            const itemRows = (order.items || []).map((item) => {
                return `<div class="row-between muted"><span>${escapeHtml(item.name || 'Product')} x ${Number(item.quantity || 0)}</span><span>${formatCurrency(item.subtotal || 0)}</span></div>`;
            }).join('');

            return `
                <article class="order-item">
                    <div class="row-between">
                        <strong>Order #${Number(order.id || 0)}</strong>
                        <span>${escapeHtml(order.status || 'Pending')}</span>
                    </div>
                    <div class="muted">Placed ${formatDate(order.createdAt)}</div>
                    ${itemRows}
                    <div class="row-between"><strong>Total</strong><strong>${formatCurrency(order.totalAmount || 0)}</strong></div>
                </article>
            `;
        }).join('');
    }

    function renderProfile() {
        if (!state.me) {
            profileCard.innerHTML = '<p class="muted">Profile is unavailable.</p>';
            return;
        }

        profileCard.innerHTML = `
            <h3 style="margin-top:0">Account</h3>
            <p><strong>Name:</strong> ${escapeHtml(state.me.name || 'N/A')}</p>
            <p><strong>Username:</strong> ${escapeHtml(state.me.username || 'N/A')}</p>
            <p><strong>Verified:</strong> ${state.me.isVerified ? 'Yes' : 'No'}</p>
            <p><strong>Roles:</strong> ${escapeHtml((state.me.roles || []).join(', ') || 'N/A')}</p>
            <p class="muted">API token is generated server-side for this session.</p>
        `;
    }

    function loadCart() {
        try {
            const stored = window.localStorage.getItem(cartStorageKey);
            const parsed = stored ? JSON.parse(stored) : [];
            return Array.isArray(parsed) ? parsed : [];
        } catch (error) {
            return [];
        }
    }

    function persistCart() {
        window.localStorage.setItem(cartStorageKey, JSON.stringify(state.cart));
    }

    async function apiRequest(path, options = {}) {
        const headers = {
            Authorization: `Bearer ${apiToken}`,
            'Content-Type': 'application/json',
        };

        const response = await fetch(path, {
            ...options,
            headers: { ...headers, ...(options.headers || {}) },
        });

        const payload = await response.json().catch(() => null);
        const failed = !response.ok || !payload || payload.status !== 'success';

        if (failed) {
            throw new Error(payload?.message || 'Request failed.');
        }

        return payload.data || {};
    }

    function showToast(message, isError = false) {
        toast.textContent = message;
        toast.classList.toggle('error', isError);
        toast.classList.add('show');
        window.setTimeout(() => toast.classList.remove('show'), 2300);
    }

    function formatCurrency(value) {
        return new Intl.NumberFormat('en-PH', {
            style: 'currency',
            currency: 'PHP',
            minimumFractionDigits: 2,
        }).format(Number(value || 0));
    }

    function formatDate(isoDate) {
        if (!isoDate) {
            return 'unknown date';
        }

        const date = new Date(isoDate);
        if (Number.isNaN(date.getTime())) {
            return 'unknown date';
        }

        return date.toLocaleString();
    }

    function escapeHtml(value) {
        return String(value)
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#39;');
    }

    function escapeAttr(value) {
        return escapeHtml(value);
    }
})();
</script>
</body>
</html>
