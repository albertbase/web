{% extends 'base_admin.html.twig' %}

{% block title %}Product List{% endblock %}

{% block body %}
<div class="container-fluid py-4">

  <!-- Header -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0 fw-bold">🍰 Product List</h2>
    <a href="{{ path('admin_products_new') }}" class="btn btn-success sweetoria-add-btn">
      <i class="bi bi-plus-circle"></i> Add New Product
    </a>
  </div>

  <!-- Filter Form -->
  <form method="get" action="{{ path('admin_products') }}" class="row g-3 mb-4 sweetoria-filter">
    <div class="col-md-6">
      <input type="text" name="search" value="{{ searchTerm }}" class="form-control sweetoria-search"
             placeholder="🔍 Search by name">
    </div>

    <div class="col-md-4">
      <select name="category" class="form-select sweetoria-select" onchange="this.form.submit()">
        <option value="">All Categories</option>
        {% for category in categories %}
          <option value="{{ category.name }}" {% if categoryFilter == category.name %}selected{% endif %}>
            {{ category.name }}
          </option>
        {% endfor %}
      </select>
    </div>

    <div class="col-md-2">
      <button type="submit" class="btn btn-primary w-100 sweetoria-filter-btn">
        <i class="bi bi-filter-circle"></i> Search
      </button>
    </div>
  </form>

  <!-- Product Cards -->
  <div class="row">
    {% for product in products %}
      <div class="col-md-3 mb-4">
        <div class="sweetoria-card card h-100 shadow-sm 
            {% if product.stock == 0 %}border-danger{% elseif product.stock <= 5 %}border-warning{% endif %}">

          <!-- Image -->
          {% if product.image %}
            <img src="{{ asset('uploads/products/' ~ product.image) }}" class="card-img-top sweetoria-img" alt="{{ product.name }}">
          {% else %}
            <img src="{{ asset('images/no-image.png') }}" class="card-img-top sweetoria-img" alt="No image">
          {% endif %}

          <div class="card-body d-flex flex-column">

            <h5 class="card-title fw-bold">{{ product.name }}</h5>

            <p class="card-text mb-2">
              <span class="sweetoria-price">₱{{ product.price|number_format(2) }}</span><br>
              <span class="badge bg-light text-dark mt-1">
                {{ product.category ? product.category.name : 'Uncategorized' }}
              </span>
            </p>

            <!-- Stock Badge -->
            <div class="mb-3">
              {% if product.stock == 0 %}
                <span class="badge bg-danger">Out of Stock</span>
              {% elseif product.stock <= 5 %}
                <span class="badge bg-warning text-dark">Low Stock ({{ product.stock }})</span>
              {% else %}
                <span class="badge bg-success">In Stock ({{ product.stock }})</span>
              {% endif %}
            </div>

            
            <!-- Buttons -->
            <div class="mt-auto d-flex justify-content-between">
            
            {# {% if is_granted('PRODUCT_EDIT', product) %} #}
              <a href="{{ path('admin_products_edit', {id: product.id}) }}" 
                 class="btn btn-sm btn-outline-warning sweetoria-edit-btn">
                <i class="bi bi-pencil-square"></i> Edit
              </a>
              {# {% endif %} #}
              {# {{ dump(product.createdBy) }}
              {{ dump(app.user) }}
              {{ dump(is_granted('PRODUCT_DELETE', product)) }} #}

              {% if is_granted('PRODUCT_DELETE', product) %}
              <form method="post" action="{{ path('admin_products_delete', {id: product.id}) }}"
                    onsubmit="return confirm('Are you sure you want to delete this product?');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
                <button type="submit" class="btn btn-sm btn-outline-danger sweetoria-delete-btn">
                  <i class="bi bi-trash"></i> Delete
                </button>
              </form>
              {% endif %}
            </div>

          </div>
        </div>
      </div>
    {% else %}
      <p class="text-muted">No products found.</p>
    {% endfor %}
  </div>
</div>

<style>
  /* Search + Select */
  .sweetoria-search, .sweetoria-select {
    border-radius: 10px;
    padding: 10px 14px;
    transition: all 0.25s ease;
  }

  .sweetoria-search:focus, .sweetoria-select:focus {
    border-color: #6f42c1;
    box-shadow: 0 0 0 4px rgba(111, 66, 193, 0.15);
  }

  /* Add Button */
  .sweetoria-add-btn {
    font-weight: 600;
    padding: 10px 18px;
    border-radius: 10px;
    transition: transform 0.2s ease;
  }

  .sweetoria-add-btn:hover {
    transform: translateY(-2px);
  }

  /* Cards */
  .sweetoria-card {
    border-radius: 14px;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    overflow: hidden;
  }

  .sweetoria-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 25px rgba(0,0,0,0.12);
  }

  /* Product Image */
  .sweetoria-img {
    height: 180px;
    object-fit: cover;
    border-bottom: 1px solid #eee;
  }

  /* Price */
  .sweetoria-price {
    font-size: 1.2rem;
    font-weight: 700;
    color: #6f42c1;
  }

  /* Buttons */
  .sweetoria-edit-btn, .sweetoria-delete-btn {
    border-radius: 8px;
    transition: all 0.2s ease;
  }

  .sweetoria-edit-btn:hover {
    background: #ffdd8a;
    border-color: #ffdd8a;
  }

  .sweetoria-delete-btn:hover {
    background: #ffb3b3;
    border-color: #ffb3b3;
  }
</style>
{% endblock %}
