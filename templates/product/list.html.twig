
{% extends 'base.html.twig' %}
{% block title %}Menu{% endblock %}

{% block body %}

 {# <link rel="stylesheet" href="{{ asset('css/product_list.css') }}"> #}

<div class="container mt-4">

  {# ✅ Flash messages #}
  {% for label, messages in app.flashes %}
    {% for message in messages %}
      <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
        {{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    {% endfor %}
  {% endfor %}

  {# ✅ Search bar #}
  <form method="get" action="{{ path('product_list') }}" class="mb-3">
    <div class="input-group">
      <input type="text" name="q" class="form-control" placeholder="Search products..." value="{{ search }}">
      {% if selectedCategory %}
        <input type="hidden" name="category" value="{{ selectedCategory }}">
      {% endif %}
      <button class="btn btn-outline-secondary" type="submit">Search</button>
    </div>
  </form>

  <h2 class="mb-4 text-center fw-bold">🍰 Our Menu</h2>

  {# ✅ Dynamic Bakery-Themed Category Filter #}
  <div class="mb-4 text-center">
    <h5 class="fw-bold mb-3">🥐 Browse by Category</h5>
    <div class="d-flex flex-wrap justify-content-center gap-2">
      <a href="{{ path('product_list', search ? {q: search} : {}) }}"
         class="category-pill {{ not selectedCategory ? 'active' : '' }}">
        🍽️ All
      </a>
      {% for category in categories %}
        <a href="{{ path('product_list', search ? {category: category.name, q: search} : {category: category.name}) }}"
           class="category-pill {{ selectedCategory == category.name ? 'active' : '' }}">
          {{ category.name|lower == 'bread' ? '🥖' :
             category.name|lower == 'cupcake' ? '🧁' :
             category.name|lower == 'dessert' ? '🍨' :
             category.name|lower == 'cakes' ? '🎂' :
             '🍩' }} {{ category.name }}
        </a>
      {% endfor %}
    </div>
  </div>

  {# ✅ Product cards #}
  <div class="row">
    {% for product in products %}
      <div class="col-md-6 col-lg-4 mb-4">
        <div class="card h-100 border-0 shadow-sm product-card">
          {% if product.image %}
            <img src="{{ asset('uploads/products/' ~ product.image) }}" class="card-img-top" alt="{{ product.name }}">
          {% else %}
            <img src="{{ asset('images/no-image.png') }}" class="card-img-top" alt="No image">
          {% endif %}

          <div class="card-body d-flex flex-column justify-content-between bg-gradient-bakery">
            <div>
              <h5 class="card-title text-center fw-bold">{{ product.name }}</h5>
              <p class="card-text text-center small">
                {{ product.description|length > 100 ? product.description|slice(0, 100) ~ '…' : product.description }}
              </p>
            </div>

            <div class="text-center mt-2">
              <p class="mb-1 fw-bold fs-5">₱{{ product.price|number_format(2) }}</p>
              <p class="text-muted small">Stock: {{ product.stock }}</p>
            </div>

            <form method="post" action="{{ path('cart_add', {id: product.id}) }}" class="mt-3">
              <input type="hidden" name="_token" value="{{ csrf_token('cart_add_' ~ product.id) }}">
              <div class="d-grid">
                <button type="submit" class="btn btn-light fw-bold"
                  {% if product.stock == 0 %}disabled{% endif %}>
                  🛒 Add to Cart
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
    {% else %}
      <p class="text-muted text-center">No products available.</p>
    {% endfor %}
  </div>
</div>



{# ✅ Styles #}

{% endblock %}
