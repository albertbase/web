{% extends 'base.html.twig' %}
{% block title %}Menu{% endblock %}

{% block body %}
<div class="container mt-4 menu-catalog">
  {% for label, messages in app.flashes %}
    {% for message in messages %}
      <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
        {{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    {% endfor %}
  {% endfor %}

  <form method="get" action="{{ path('app_menu') }}" class="mb-3">
    <div class="input-group">
      <input type="text" name="q" class="form-control" placeholder="Search products..." value="{{ search }}">
      {% if selectedCategory %}
        <input type="hidden" name="category" value="{{ selectedCategory }}">
      {% endif %}
      <button class="btn btn-outline-secondary" type="submit">Search</button>
    </div>
  </form>

  <div class="mb-4 text-center">
    <a href="{{ path('custom_cake_builder') }}" class="btn btn-primary btn-lg shadow-sm">Build Your Own Cake</a>
  </div>

  <h2 class="mb-4 text-center fw-bold">Our Menu</h2>

  <div class="mb-4 text-center">
    <h5 class="fw-bold mb-3">Browse by category</h5>
    <div class="d-flex flex-wrap justify-content-center gap-2">
      <a href="{{ path('app_menu', search ? {q: search} : {}) }}"
         class="category-pill {{ not selectedCategory ? 'active' : '' }}">
        All
      </a>
      {% for category in categories %}
        <a href="{{ path('app_menu', search ? {category: category.name, q: search} : {category: category.name}) }}"
           class="category-pill {{ selectedCategory == category.name ? 'active' : '' }}">
          {{ category.name }}
        </a>
      {% endfor %}
    </div>
  </div>

  <div class="row">
    {% for product in products %}
      <div class="col-md-6 col-lg-4 mb-4">
        <div class="card h-100 border-0 shadow-sm product-card">
          {% if product.image %}
            <img src="{{ asset('uploads/products/' ~ product.image) }}" class="card-img-top" alt="{{ product.name }}">
          {% else %}
            <img src="{{ asset('image/logo.png') }}" class="card-img-top" alt="No image available">
          {% endif %}

          <div class="card-body d-flex flex-column justify-content-between bg-gradient-bakery">
            <div>
              <h5 class="card-title text-center fw-bold">{{ product.name }}</h5>
              <p class="card-text text-center small">
                {{ product.description|length > 100 ? product.description|slice(0, 100) ~ '...' : product.description }}
              </p>
            </div>

            <div class="text-center mt-2">
              <p class="mb-1 fw-bold fs-5">PHP {{ product.price|number_format(2) }}</p>
              <p class="text-muted small">Stock: {{ product.stock }}</p>
            </div>

            {% include 'partials/_product_purchase_buttons.html.twig' with {
              product: product,
              buy_btn_class: 'btn-primary',
              add_btn_class: 'btn-light'
            } %}
          </div>
        </div>
      </div>
    {% else %}
      <p class="text-muted text-center">No products available.</p>
    {% endfor %}
  </div>
</div>
{% endblock %}
