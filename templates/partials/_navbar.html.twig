{% set currentRoute = app.request.attributes.get('_route') %}
{% set cartCount = app.user ? app.session.get('cart', [])|length : 0 %}

<nav class="navbar sticky-top compact-navbar navbar-expand navbar-dark">
  <div class="container-fluid compact-navbar-shell">
    <a class="navbar-brand compact-navbar-brand d-flex align-items-center gap-2" href="{{ path('app_landing') }}">
      <img src="{{ asset('image/logo.png') }}" alt="Sweetoria Logo" class="compact-navbar-logo">
      
    </a>

    <div class="compact-navbar-collapse">
      <ul class="navbar-nav me-auto mb-2 mb-lg-0 compact-navbar-nav">
        <li class="nav-item">
          <a class="nav-link {{ currentRoute in ['app_landing', 'app_home'] ? 'active' : '' }}" href="{{ path('app_landing') }}">Home</a>
        </li>
        <li class="nav-item">
          <a class="nav-link {{ currentRoute in ['app_menu', 'product_list'] ? 'active' : '' }}" href="{{ path('app_menu') }}">Menu</a>
        </li>
        <li class="nav-item">
          <a class="nav-link {{ currentRoute == 'custom_cake_builder' ? 'active' : '' }}" href="{{ path('custom_cake_builder') }}">Build Cake</a>
        </li>
        <li class="nav-item">
          <a class="nav-link {{ currentRoute == 'category_list' ? 'active' : '' }}" href="{{ path('category_list') }}">Category</a>
        </li>
        <li class="nav-item">
          <a class="nav-link {{ currentRoute == 'home' ? 'active' : '' }}" href="{{ path('home') }}">About Us</a>
        </li>
        <li class="nav-item">
          <a class="nav-link {{ currentRoute == 'app_contact' ? 'active' : '' }}" href="{{ path('app_contact') }}">Contact</a>
        </li>

        {% if app.user and not is_granted('ROLE_STAFF') %}
          <li class="nav-item">
            <a class="nav-link {{ currentRoute in ['customer_profile', 'customer_profile_edit', 'customer_change_password'] ? 'active' : '' }}" href="{{ path('customer_profile') }}">Profile</a>
          </li>
        {% endif %}
        {% if app.user and is_granted('ROLE_STAFF') %}
          <li class="nav-item">
            <a class="nav-link {{ currentRoute in ['staff_profile', 'staff_profile_edit', 'staff_change_password'] ? 'active' : '' }}" href="{{ path('staff_profile') }}">My Account</a>
          </li>
        {% endif %}

        {% if is_granted('ROLE_STAFF') %}
          <li class="nav-item">
            <a class="nav-link {{ currentRoute == 'admin_orders' ? 'active' : '' }}" href="{{ path('admin_orders') }}">Manage Orders</a>
          </li>
          <li class="nav-item">
            <a class="nav-link {{ currentRoute == 'admin_products' ? 'active' : '' }}" href="{{ path('admin_products') }}">Manage Products</a>
          </li>
        {% endif %}
        {% if is_granted('ROLE_ADMIN') %}
          <li class="nav-item">
            <a class="nav-link {{ currentRoute == 'admin_dashboard' ? 'active' : '' }}" href="{{ path('admin_dashboard') }}">Dashboard</a>
          </li>
        {% endif %}
      </ul>

      <div class="compact-navbar-actions d-flex align-items-center gap-2">
        {% if app.user %}
          <a href="{{ path('cart_show') }}" class="cart-pill {{ currentRoute == 'cart_show' ? 'active' : '' }}">
            <span>Cart</span>
            <span class="cart-pill-count">{{ cartCount }}</span>
          </a>
        {% endif %}

        {% if app.user %}
          <form method="post" action="{{ path('app_logout') }}" class="logout-form m-0">
            <button type="submit" class="auth-link auth-link-solid border-0 bg-transparent">Log Out</button>
          </form>
        {% else %}
          <a href="{{ path('app_login') }}" class="auth-link auth-link-ghost {{ currentRoute == 'app_login' ? 'active' : '' }}">Sign In</a>
          <a href="{{ path('app_register') }}" class="auth-link auth-link-solid {{ currentRoute == 'app_register' ? 'active' : '' }}">Register</a>
        {% endif %}
      </div>
    </div>
  </div>
</nav>

<script>
  window.addEventListener('scroll', () => {
    const navbar = document.querySelector('.navbar.compact-navbar');
    if (!navbar) return;

    if (window.scrollY > 10) {
      navbar.style.backdropFilter = 'blur(8px)';
      navbar.style.webkitBackdropFilter = 'blur(8px)';
      navbar.style.backgroundColor = 'rgba(253, 246, 236, 0.8)';
    } else {
      navbar.style.backdropFilter = 'blur(0px)';
      navbar.style.webkitBackdropFilter = 'blur(0px)';
      navbar.style.backgroundColor = 'transparent';
    }
  });
</script>
