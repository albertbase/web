{% extends 'base.html.twig' %}
{% block title %}All Categories{% endblock %}

{% block body %}
<div class="container py-4 category-catalog">
  <section class="text-center mb-5">
    <p class="section-kicker mb-2">Categories</p>
    <h1 class="display-5 fw-bold mb-3">Cakes, pastries, and desserts</h1>
    <p class="text-muted mb-0 mx-auto" style="max-width: 720px;">
      Explore each bakery category with products grouped neatly for easier browsing.
    </p>
  </section>

  <div class="row g-4">
    {% for category in categories %}
      <div class="col-12">
        <section class="p-4 p-lg-5 rounded-4 shadow-sm bg-white border">
          <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
            <div>
              <p class="section-kicker mb-1">{{ category.name }}</p>
              <h2 class="h3 fw-bold mb-0">{{ category.name }}</h2>
            </div>
            <span class="badge rounded-pill text-bg-light px-3 py-2">
              {{ category.products|length }} products
            </span>
          </div>

          {% if category.products is not empty %}
            <div class="row g-4">
              {% for product in category.products %}
                <div class="col-md-6 col-lg-4">
                  <article class="card h-100 border-0 shadow-sm overflow-hidden">
                    {% if product.image %}
                      <img src="{{ asset('uploads/products/' ~ product.image) }}" class="card-img-top" alt="{{ product.name }}">
                    {% else %}
                      <img src="{{ asset('image/logo.png') }}" class="card-img-top" alt="{{ product.name }}">
                    {% endif %}
                    <div class="card-body">
                      <h3 class="h5 fw-bold mb-2">{{ product.name }}</h3>
                      <p class="text-muted small mb-3">
                        {{ product.description|length > 110 ? product.description|slice(0, 110) ~ '...' : product.description }}
                      </p>
                      <div class="d-flex justify-content-between align-items-center">
                        <strong class="text-dark">PHP {{ product.price|number_format(2) }}</strong>
                        <small class="text-muted">Stock: {{ product.stock }}</small>
                      </div>
                    </div>
                  </article>
                </div>
              {% endfor %}
            </div>
          {% else %}
            <p class="text-muted mb-0">No products in this category yet.</p>
          {% endif %}
        </section>
      </div>
    {% endfor %}
  </div>
</div>
{% endblock %}
