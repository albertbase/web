{% extends 'base_admin.html.twig' %}

{% block title %}Sweetoria Dashboard{% endblock %}

{% block body %}
<style>
    :root {
        --bakery-rose: #fff0f3;
        --bakery-rose-dark: #ff85a1;
        --bakery-mint: #f0fff4;
        --bakery-mint-dark: #38a169;
        --bakery-cream: #fffaf0;
        --bakery-cream-dark: #d69e2e;
        --bakery-caramel: #fef3e2;
        --bakery-caramel-dark: #975a16;
        --surface: #ffffff;
        --background: #f8f9fa;
        --text-main: #2d3436;
        --text-muted: #636e72;
        --shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
    }

    .admin-page {
        padding: 2.5rem;
        background-color: var(--background);
        min-height: 100vh;
        font-family: 'Inter', -apple-system, sans-serif;
    }

    /* Section Labels */
    .section-label {
        margin: 2.5rem 0 1.25rem 0;
        display: flex;
        align-items: center;
        gap: 1rem;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--text-muted);
    }
    .section-label::after {
        content: "";
        height: 1px;
        flex-grow: 1;
        background: #e0e0e0;
    }

    /* Hero Section */
    .admin-hero {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 2rem;
    }
    .page-title { font-weight: 850; color: var(--text-main); letter-spacing: -1.5px; }
    .page-kicker { color: var(--bakery-rose-dark); font-weight: 700; text-transform: uppercase; font-size: 0.85rem; }

    /* Quick Nav Cards */
    .quick-nav-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1.25rem;
    }
    .quick-nav-card {
        background: var(--surface);
        padding: 1.5rem;
        border-radius: 20px;
        display: flex;
        align-items: center;
        gap: 1.25rem;
        text-decoration: none !important;
        color: var(--text-main);
        transition: all 0.3s ease;
        box-shadow: var(--shadow);
        border: 1px solid rgba(0,0,0,0.02);
    }
    .quick-nav-card:hover { transform: translateY(-5px); box-shadow: 0 15px 35px rgba(0,0,0,0.08); }
    .quick-nav-icon {
        width: 50px; height: 50px;
        border-radius: 15px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.4rem;
    }

    /* Metric Cards */
    .metric-card {
        background: var(--surface);
        padding: 1.75rem;
        border-radius: 24px;
        box-shadow: var(--shadow);
        position: relative;
        overflow: hidden;
    }
    .metric-label { font-weight: 600; color: var(--text-muted); font-size: 0.9rem; }
    .metric-value { font-size: 2.2rem; font-weight: 850; display: block; margin: 0.2rem 0; color: var(--text-main); }
    .metric-icon { position: absolute; right: 1.5rem; top: 1.5rem; font-size: 1.8rem; opacity: 0.1; }

    /* Panel Cards */
    .panel-card {
        background: var(--surface);
        padding: 2rem;
        border-radius: 28px;
        box-shadow: var(--shadow);
        border: 1px solid rgba(0,0,0,0.02);
        margin-bottom: 2rem;
    }
    .panel-title { font-weight: 800; font-size: 1.35rem; letter-spacing: -0.5px; }

    /* Table Styling */
    .admin-table thead th {
        background: #fbfbfb;
        border-bottom: 2px solid #f1f1f1;
        font-size: 0.7rem;
        text-transform: uppercase;
        font-weight: 800;
        color: var(--text-muted);
        padding: 1rem;
    }
    .admin-table tbody td { padding: 1.1rem 1rem; border-bottom: 1px solid #f8f9fa; font-size: 0.9rem; }

    /* Status & Action Pills */
    .status-pill, .action-badge {
        padding: 0.4rem 0.9rem;
        border-radius: 10px;
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: capitalize;
    }
    .status-active { background: var(--bakery-mint); color: var(--bakery-mint-dark); }
    .status-pending { background: var(--bakery-caramel); color: var(--bakery-caramel-dark); }
    .action-badge { background: #eee; color: #555; border: 1px solid #ddd; }

    /* Activity Specifics */
    .log-user { font-weight: 700; color: var(--text-main); }
    .log-details { font-family: 'Monaco', 'Consolas', monospace; font-size: 0.8rem; color: #666; }

    /* Utility Colors */
    .quick-nav-rose .quick-nav-icon, .metric-card-rose .metric-icon { background: var(--bakery-rose); color: var(--bakery-rose-dark); }
    .quick-nav-caramel .quick-nav-icon, .metric-card-caramel .metric-icon { background: var(--bakery-caramel); color: var(--bakery-caramel-dark); }
    .quick-nav-cream .quick-nav-icon, .metric-card-cream .metric-icon { background: var(--bakery-cream); color: var(--bakery-cream-dark); }
    .quick-nav-mint .quick-nav-icon, .metric-card-mint .metric-icon { background: var(--bakery-mint); color: var(--bakery-mint-dark); }
    tr.row--new { animation: orderHighlight 1.5s ease-out; }
    @keyframes orderHighlight {
        from { background-color: #d1e7dd; }
        to { background-color: transparent; }
    }
</style>

<div class="admin-page">
    <section class="admin-hero">
        <div class="hero-copy">
            <p class="page-kicker mb-1">Sweetoria Admin</p>
            <h1 class="page-title mb-2">Welcome back, Boss</h1>
            {#<div class="hero-badges">
                <span class="hero-badge hero-badge-primary px-3 py-1 rounded-pill">
                    <i class="bi bi-shield-lock me-1"></i>Secure Session
                </span>
            </div>#}
        </div>
       {# <div class="admin-hero-actions">
            <a href="{{ path('admin_products') }}" class="btn btn-dark rounded-pill px-4 me-2">Manage Store</a>
            <a href="{{ path('admin_orders') }}" class="btn btn-outline-dark rounded-pill px-4">Sales Report</a>
        </div>#}
    </section>

    <div class="section-label"><span>Quick Navigation</span></div>
    <section class="quick-nav-grid">
        <a href="{{ path('admin_products') }}" class="quick-nav-card quick-nav-rose">
            <span class="quick-nav-icon"><i class="bi bi-box-seam"></i></span>
            <span><strong>Products</strong><br><small class="text-muted">Inventory</small></span>
        </a>
        <a href="{{ path('admin_orders') }}" class="quick-nav-card quick-nav-caramel">
            <span class="quick-nav-icon"><i class="bi bi-bag-check"></i></span>
            <span><strong>Orders</strong><br><small class="text-muted">Transactions</small></span>
        </a>
        <a href="{{ path('admin_staff_index') }}" class="quick-nav-card quick-nav-cream">
            <span class="quick-nav-icon"><i class="bi bi-people"></i></span>
            <span><strong>Staff</strong><br><small class="text-muted">Team Mgmt</small></span>
        </a>
        <a href="{{ path('admin_activity_logs_index') }}" class="quick-nav-card quick-nav-mint">
            <span class="quick-nav-icon"><i class="bi bi-clock-history"></i></span>
            <span><strong>Activity</strong><br><small class="text-muted">Audit Log</small></span>
        </a>
    </section>

    <div id="dashboard-live-indicator" class="alert alert-info py-2 small mb-3 d-none">
        <i class="bi bi-broadcast"></i> Live — orders and inventory update automatically
    </div>

    <div class="section-label"><span>Store Pulse</span></div>
    <section class="row row-cols-1 row-cols-sm-2 row-cols-xl-4 g-4 mb-4">
        <div class="col">
            <div class="metric-card metric-card-rose">
                <i class="bi bi-box-seam metric-icon"></i>
                <span class="metric-label">Products</span>
                <strong class="metric-value" data-metric="totalProducts">{{ totalProducts }}</strong>
            </div>
        </div>
        <div class="col">
            <div class="metric-card metric-card-cream">
                <i class="bi bi-people metric-icon"></i>
                <span class="metric-label">Users</span>
                <strong class="metric-value" data-metric="totalUsers">{{ totalUsers }}</strong>
            </div>
        </div>
        <div class="col">
            <div class="metric-card metric-card-mint">
                <i class="bi bi-person-badge metric-icon"></i>
                <span class="metric-label">Staff</span>
                <strong class="metric-value" data-metric="totalStaff">{{ totalStaff }}</strong>
            </div>
        </div>
        <div class="col">
            <div class="metric-card metric-card-caramel">
                <i class="bi bi-bag-check metric-icon"></i>
                <span class="metric-label">Orders</span>
                <strong class="metric-value" data-metric="totalOrders">{{ totalOrders }}</strong>
            </div>
        </div>
    </section>

    <div class="section-label"><span>Live Store Feed</span></div>
    <section class="row g-4 mb-4">
        <div class="col-lg-7">
            <div class="panel-card h-100">
                <div class="panel-head d-flex justify-content-between align-items-center mb-3">
                    <h2 class="panel-title mb-0">Recent Orders</h2>
                    <a href="{{ path('admin_orders') }}" class="btn btn-sm btn-outline-dark rounded-pill px-3">All Orders</a>
                </div>
                <div class="table-responsive">
                    <table class="table admin-table align-middle mb-0" data-dashboard-orders-table>
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Customer</th>
                                <th>Status</th>
                                <th>Total</th>
                                <th>Created</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% if recentOrders is empty %}
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">No orders yet.</td>
                            </tr>
                        {% endif %}
                        {% for order in recentOrders %}
                            <tr data-order-id="{{ order.id }}">
                                <td class="fw-bold">#{{ order.id }}</td>
                                <td>{{ order.customerName }}</td>
                                <td>
                                    {% set badge = {
                                      'Pending': 'bg-warning text-dark',
                                      'Paid': 'bg-info text-dark',
                                      'Shipped': 'bg-primary',
                                      'Delivered': 'bg-success'
                                    }[order.status] ?? 'bg-secondary' %}
                                    <span class="badge {{ badge }} px-2 py-1">{{ order.status }}</span>
                                </td>
                                <td class="fw-semibold">₱{{ order.totalAmount|number_format(2) }}</td>
                                <td class="text-muted small">{{ order.createdAt|date('M d, H:i') }}</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="panel-card h-100">
                <div class="panel-head d-flex justify-content-between align-items-center mb-3">
                    <h2 class="panel-title mb-0">Products</h2>
                    <a href="{{ path('admin_products') }}" class="btn btn-sm btn-outline-dark rounded-pill px-3">Inventory</a>
                </div>
                <div class="table-responsive">
                    <table class="table admin-table align-middle mb-0" data-dashboard-products-table>
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>Stock</th>
                                <th>Price</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% if recentProducts is empty %}
                            <tr>
                                <td colspan="3" class="text-center py-4 text-muted">No products yet.</td>
                            </tr>
                        {% endif %}
                        {% for product in recentProducts %}
                            <tr data-product-id="{{ product.id }}">
                                <td>
                                    <span class="fw-semibold">{{ product.name }}</span>
                                    {% if product.category %}
                                        <br><small class="text-muted">{{ product.category.name }}</small>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if product.stock == 0 %}
                                        <span class="badge bg-danger" data-stock-badge>Out (0)</span>
                                    {% elseif product.stock <= 5 %}
                                        <span class="badge bg-warning text-dark" data-stock-badge>Low ({{ product.stock }})</span>
                                    {% else %}
                                        <span class="badge bg-success" data-stock-badge>In ({{ product.stock }})</span>
                                    {% endif %}
                                </td>
                                <td class="fw-semibold" data-product-price>₱{{ product.price|number_format(2) }}</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </section>

    <div class="section-label"><span>System Activity Log</span></div>
    <section class="row">
        <div class="col-12">
            <div class="panel-card">
                <div class="panel-head d-flex justify-content-between align-items-center mb-4">
                    <h2 class="panel-title mb-0">Recent Changes & Logins</h2>
                    <a href="{{ path('admin_activity_logs_index') }}" class="btn btn-sm btn-outline-dark rounded-pill px-3">Full Audit</a>
                </div>
                <div class="table-responsive">
                    <table class="table admin-table align-middle">
                        <thead>
                            <tr>
                                <th>User / Staff</th>
                                <th>Role</th>
                                <th>Action</th>
                                <th>Entity Affected</th>
                                <th>Detail Snippet</th>
                                <th>Timestamp</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% for log in recentLogs %}
                            <tr>
                                <td><span class="log-user">{{ log.username }}</span></td>
                                <td><small class="badge bg-light text-dark border">{{ log.userRole }}</small></td>
                                <td><span class="action-badge">{{ log.action }}</span></td>
                                <td>
                                    {% if log.entityType %}
                                        <span class="text-muted">{{ log.entityType }}</span> 
                                        <span class="fw-bold text-dark">#{{ log.entityId }}</span>
                                    {% else %}
                                        <span class="text-muted">—</span>
                                    {% endif %}
                                </td>
                                <td><div class="log-details text-truncate" style="max-width: 200px;">{{ log.details ?: 'No additional data' }}</div></td>
                                <td class="text-muted small">{{ log.timestamp|date('M d, H:i') }}</td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted italic">
                                    <i class="bi bi-inbox d-block fs-2 mb-2"></i>
                                    No recent activity has been logged yet.
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </section>
</div>

<script>
  window.SWEETORIA_DASHBOARD_REALTIME = {
    feedUrl: '{{ path('admin_dashboard_live') }}',
    mercureUrl: '{{ mercure_public_url|default('/.well-known/mercure') }}',
    pollIntervalMs: 2500,
  };
  document.getElementById('dashboard-live-indicator')?.classList.remove('d-none');
</script>
<script src="{{ asset('js/admin-dashboard-realtime.js') }}"></script>
{% endblock %}