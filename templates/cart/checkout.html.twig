{% extends 'base.html.twig' %}
{% block title %}Checkout{% endblock %}

{% block body %}
<div class="container mt-5 checkout-container checkout-page">
  <div class="text-center mb-4">
    <h2 class="checkout-title">Confirm Your Order</h2>
    <p class="checkout-subtext">Review what you are ordering before placing it.</p>
  </div>

  <div class="checkout-card mx-auto">
    <h3 class="checkout-summary-heading">Order Summary</h3>
    {% include 'cart/_cart_summary.html.twig' with { cart: cart, total: total, compact: true } %}

    <form method="post" action="{{ path('checkout') }}" class="checkout-form mt-4">
      <input type="hidden" name="_token" value="{{ csrf_token('checkout') }}">
      <div class="mb-3">
        <label for="paymentMethod" class="form-label fw-semibold">Payment Method</label>
        <select id="paymentMethod" name="paymentMethod" class="form-select" required>
          <option value="" disabled selected>Select payment method</option>
          <option value="cash">Cash</option>
          <option value="gcash">GCash</option>
          <option value="card">Card</option>
          <option value="bank_transfer">Bank Transfer</option>
        </select>
      </div>
      <button type="submit" class="btn btn-checkout w-100">Pay & Place Order</button>
    </form>
  </div>
</div>
{% endblock %}
