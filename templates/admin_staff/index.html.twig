{% extends 'base_admin.html.twig' %}

{% block title %}Staff Management | Sweetoria{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/admin_staff.css') }}">
{% endblock %}

{% block body %}
<div class="staff-workspace">
    <header class="staff-hero">
        <div class="staff-hero-content">
            <p class="staff-kicker">Team Operations</p>
            <h1 class="staff-title">Staff Management</h1>
            <p class="staff-subtitle">Oversee team access, roles, and account health in a clear, radiant workspace built for Sweetoria administrators.</p>
        </div>
        {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('admin_staff_new') }}" class="staff-btn-primary">
                <i class="bi bi-person-plus-fill"></i>
                Add Team Member
            </a>
        {% endif %}
    </header>

    <section class="staff-metrics" aria-label="Staff overview metrics">
        <article class="staff-metric">
            <span class="staff-metric-label">Total Staff</span>
            <strong class="staff-metric-value">{{ totalStaff }}</strong>
        </article>
        <article class="staff-metric">
            <span class="staff-metric-label">Active Accounts</span>
            <strong class="staff-metric-value staff-metric-value--mint">{{ activeStaff }}</strong>
        </article>
        <article class="staff-metric">
            <span class="staff-metric-label">Administrators</span>
            <strong class="staff-metric-value staff-metric-value--coral">{{ adminAccounts }}</strong>
        </article>
        <article class="staff-metric">
            <span class="staff-metric-label">Inactive</span>
            <strong class="staff-metric-value staff-metric-value--muted">{{ totalStaff - activeStaff }}</strong>
        </article>
    </section>

    <section class="staff-panel">
        <div class="staff-panel-head">
            <h2 class="staff-panel-title"><i class="bi bi-stars"></i> Recent Onboarding</h2>
        </div>
        <div class="staff-onboarding">
            {% for user in recentStaff %}
                <article class="staff-onboarding-card">
                    <div class="staff-avatar">{{ user.username|slice(0, 1)|upper }}</div>
                    <div class="flex-grow-1 min-w-0">
                        <div class="staff-onboarding-name" title="{{ user.username }}">{{ user.username }}</div>
                        <div class="staff-onboarding-date">{{ user.createdAt|date('M d, Y') }}</div>
                    </div>
                    <span class="staff-pill {{ 'ROLE_ADMIN' in user.assignedRoles ? 'staff-pill--admin' : 'staff-pill--staff' }}">
                        {{ 'ROLE_ADMIN' in user.assignedRoles ? 'Admin' : 'Staff' }}
                    </span>
                </article>
            {% else %}
                <p class="staff-empty w-100 mb-0">No staff members have been onboarded yet.</p>
            {% endfor %}
        </div>
    </section>

    <section class="staff-panel">
        <div class="staff-panel-head">
            <h2 class="staff-panel-title"><i class="bi bi-people-fill"></i> Staff Directory</h2>
            <span class="staff-pill staff-pill--staff">{{ staff|length }} members</span>
        </div>
        <div class="staff-table-wrap">
            <table class="staff-table">
                <thead>
                    <tr>
                        <th>Member</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Joined</th>
                        {% if is_granted('ROLE_ADMIN') %}
                            <th class="text-end">Actions</th>
                        {% endif %}
                    </tr>
                </thead>
                <tbody>
                    {% for user in staff %}
                        <tr>
                            <td>
                                <div class="staff-member-cell">
                                    <div class="staff-avatar staff-avatar--sm">{{ user.username|slice(0, 1)|upper }}</div>
                                    <span class="staff-member-name">{{ user.username }}</span>
                                </div>
                            </td>
                            <td>
                                {% if 'ROLE_ADMIN' in user.assignedRoles %}
                                    <span class="staff-pill staff-pill--admin">Administrator</span>
                                {% elseif 'ROLE_STAFF' in user.assignedRoles %}
                                    <span class="staff-pill staff-pill--staff">Staff Member</span>
                                {% endif %}
                            </td>
                            <td>
                                <span class="staff-pill {{ user.isActive ? 'staff-pill--active' : 'staff-pill--disabled' }}">
                                    {{ user.isActive ? 'Active' : 'Disabled' }}
                                </span>
                            </td>
                            <td class="text-muted small">{{ user.createdAt|date('M d, Y') }}</td>
                            {% if is_granted('ROLE_ADMIN') %}
                                <td class="text-end">
                                    <div class="staff-actions">
                                        <a href="{{ path('admin_staff_edit', {id: user.id}) }}" class="staff-action-btn" title="Edit member">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form method="post" action="{{ path('admin_staff_delete', {id: user.id}) }}" class="d-inline" onsubmit="return confirm('Delete this staff account permanently?');">
                                            <button type="submit" class="staff-action-btn staff-action-btn--danger" title="Delete member">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            {% endif %}
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="{{ is_granted('ROLE_ADMIN') ? 5 : 4 }}" class="text-center py-4 text-muted">
                                No staff accounts found. Add your first team member to get started.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
</div>
{% endblock %}
