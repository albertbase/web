{% extends 'base_admin.html.twig' %}

{% block title %}Edit Staff | Sweetoria{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/admin_staff.css') }}">
{% endblock %}

{% block body %}
<div class="staff-workspace staff-form-page">
    <header class="staff-hero">
        <div class="staff-hero-content">
            <p class="staff-kicker">Team Operations</p>
            <h1 class="staff-title">Edit Staff Account</h1>
            <p class="staff-subtitle">Update access, credentials, and status for <strong>{{ user.username }}</strong>.</p>
        </div>
        <a href="{{ path('admin_staff_index') }}" class="staff-btn-secondary">
            <i class="bi bi-arrow-left"></i> Back to Staff
        </a>
    </header>

    <div class="staff-form-card">
        {{ form_start(form, { attr: { class: 'staff-form' } }) }}

        <div class="staff-form-grid">
            <div class="staff-field">
                {{ form_label(form.username) }}
                {{ form_widget(form.username, { attr: { class: 'form-control' } }) }}
                {{ form_errors(form.username) }}
            </div>

            <div class="staff-field">
                {{ form_label(form.status) }}
                {{ form_widget(form.status, { attr: { class: 'form-select' } }) }}
                {{ form_errors(form.status) }}
            </div>

            <div class="staff-field" style="grid-column: 1 / -1;">
                <label class="form-label">Roles</label>
                <div class="staff-role-pills">
                    {% for child in form.roles %}
                        <label class="staff-role-pill">
                            {{ form_widget(child) }}
                            <span>{{ child.vars.label }}</span>
                        </label>
                    {% endfor %}
                </div>
                {{ form_errors(form.roles) }}
            </div>

            <div class="staff-field" style="grid-column: 1 / -1;">
                {{ form_label(form.plainPassword) }}
                {{ form_widget(form.plainPassword, { attr: { class: 'form-control', placeholder: 'Leave blank to keep current password' } }) }}
                {{ form_errors(form.plainPassword) }}
            </div>
        </div>

        <div class="staff-form-actions">
            <button type="submit" class="staff-btn-primary">
                <i class="bi bi-check-circle-fill"></i> Save Changes
            </button>
            <a href="{{ path('admin_staff_index') }}" class="staff-btn-secondary">Cancel</a>
        </div>

        {{ form_end(form) }}
    </div>

    {% if is_granted('ROLE_ADMIN') %}
        <aside class="staff-danger-zone">
            <h3><i class="bi bi-exclamation-triangle-fill"></i> Danger Zone</h3>
            <p>Deleting this staff account is permanent and cannot be undone.</p>
            <form method="post"
                  action="{{ path('admin_staff_delete', {id: user.id}) }}"
                  onsubmit="return confirm('Are you sure you want to delete this account?');">
                <button type="submit" class="staff-btn-danger">
                    <i class="bi bi-trash-fill"></i> Delete Account
                </button>
            </form>
        </aside>
    {% endif %}
</div>
{% endblock %}
