{# =========================
   B. Staff Management
   ========================= #}
<section class="staff-management">
  <h3>Staff Management</h3>
  <table class="list-table">
    <thead>
      <tr>
        {# <th>Name</th> #}
        <th>Username</th>
        <th>Roles</th>
        <th>Verification</th>
        <th>Status</th>
        <th>Created At</th>
        <th>Operation</th>
        <th>Action</th>
      </tr>
    </thead>
    <tbody>
      {% for user in users %}
        <tr>
          {# <td>{{ user.name }}</td> #}
          <td>{{ user.username }}</td>
          <td>
            {% for label in user.roleLabels %}
                <span class="badge role-badge">{{ label }}</span>
            {% endfor %}
            </td>

          <td>
            {% if user.isVerified %}
              <span class="verified-badge">
                <i class="fa fa-check-circle"></i> Verified
              </span>
            {% else %}
              <span class="verified-badge unverified">
                <i class="fa fa-clock-o"></i> Pending
              </span>
            {% endif %}
          </td>

          <td>
            {% if user.isActive %}
              <span class="status active">Active</span>
            {% else %}
              <span class="status inactive">Inactive</span>
            {% endif %}
          </td>
          <td>{{ user.createdAt|date('Y-m-d | H:i') }}</td>
          <td>
            <a href="{{ path('admin_users_edit', {id: user.id}) }}"><i class="fa fa-edit"></i></a>
            <form method="post" action="{{ path('admin_users_delete', {id: user.id}) }}" style="display:inline;" onsubmit="return confirm('Delete this user?');">
              <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
              <button type="submit" style="background:none;border:none;"><i class="fa fa-trash"></i></button>
            </form>
          </td>
          <td>
            <a href="{{ path('admin_users_login_as', {id: user.id}) }}" class="btn btn-sm btn-primary">Login</a>
          </td>
        </tr>
      {% else %}
        <tr>
          <td colspan="8">No staff found.</td>
        </tr>
      {% endfor %}
    </tbody>
  </table>
</section>
{% endblock %}
