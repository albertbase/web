<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        <link href="https://fonts.googleapis.com/css2?family=Playfair+Display&display=swap" rel="stylesheet">
        <link href="https://fonts.googleapis.com/css2?family=EB+Garamond&display=swap" rel="stylesheet">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
        {# <link rel="stylesheet" href="{{ asset('css/admin.css') }}"> #}
        


        
        <link rel="stylesheet" href="{{ asset('css/all.css') }}">

        <link rel="stylesheet" href="{{ asset('css/app.css') }}">

        {# <a href="{{ path('admin_categories') }}">Manage Categories</a> #}

        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
        {% endblock %}

        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
        {% endblock %}
    </head>
    <body>
        
        {% include 'partials/_navbar.html.twig' %}
        <div class="container" style="padding-top: 70px;">
            {% block body %}{% endblock %}
        </div>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

        {% for label, messages in app.flashes %}
        {% for message in messages %}
        <div class="alert alert-{{ label }} mt-3">{{ message }}</div>
        {% endfor %}
        {% endfor %}

    <footer class="footer">
    <div class="footer-container">

        <!-- Logo & About -->
        <div class="footer-col">
            <div class="logo1">
            <img src="{{ asset('image/logo.png') }}" alt="Brand Logo">
            </div>
            <p>Indulge in Sweetoria: A little sweetness, a lot of joy.</p>
        </div>

        <!-- Quick Links -->
        <div class="footer-col">
            <h3>Quick Links</h3>
            <ul>
                <li><a href="#">Home</a></li>
                <li><a href="#">Menu</a></li>
                <li><a href="#">Category</a></li>
                <li><a href="#">About Us</a></li>
                <li><a href="#">Contact Us</a></li>
            </ul>
        </div>

        <!-- Contact Info -->
        <div class="footer-col">
            <h3>Contact Us</h3>
            <p>📍 123 Bakery St, Sweet City</p>
            <p>📞 +63 900 123 4567</p>
            <p>✉️ hello@mybakery.com</p>
        </div>

        <!-- Social Media -->
        <div class="footer-col">
            <h3>Follow Us</h3>
            <div class="social-icons">
                <a href="#"><i class="fab fa-facebook"></i></a>
                <a href="#"><i class="fab fa-instagram"></i></a>
                <a href="#"><i class="fab fa-twitter"></i></a>
            </div>
        </div>
    </div>

    <div class="footer-bottom">
        <p>&copy; {{ "now"|date("Y") }} MyBakery. All rights reserved.</p>
    </div>
</footer>

    </body>
</html>
