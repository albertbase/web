<script>
    (function () {
        const preview = document.querySelector('[data-highlight-preview]');
        const previewName = document.querySelector('[data-highlight-name]');
        const previewRole = document.querySelector('[data-highlight-role]');
        const cards = document.querySelectorAll('[data-testimonial-card]');

        if (!preview || !previewName || !previewRole || !cards.length) {
            return;
        }

        const setActiveCard = (card) => {
            cards.forEach((item) => item.classList.toggle('is-active', item === card));
            preview.classList.remove('is-updating');
            previewName.classList.remove('is-updating');
            previewRole.classList.remove('is-updating');
            void preview.offsetWidth;
            preview.classList.add('is-updating');
            previewName.classList.add('is-updating');
            previewRole.classList.add('is-updating');
            preview.textContent = card.dataset.quote || '';
            previewName.textContent = card.dataset.name || '';
            previewRole.textContent = card.dataset.role || '';

            cards.forEach((item) => {
                item.setAttribute('aria-pressed', item === card ? 'true' : 'false');
            });
        };

        cards.forEach((card) => {
            card.setAttribute('role', 'button');
            card.setAttribute('tabindex', '0');
            card.setAttribute('aria-pressed', card.classList.contains('is-active') ? 'true' : 'false');

            card.addEventListener('click', () => setActiveCard(card));
            card.addEventListener('keydown', (event) => {
                if (event.key === 'Enter' || event.key === ' ') {
                    event.preventDefault();
                    setActiveCard(card);
                }
            });
        });
    })();
</script>
