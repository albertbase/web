{% extends 'base.html.twig' %}

{% block title %}Sweetoria | Handcrafted Sweetness{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/landing.css') }}?v=20260417-testimonials">
    <style>
        .landing-page {
            background:
                radial-gradient(circle at 14% 8%, rgba(255,255,255,0.24) 0%, rgba(255,255,255,0) 34%),
                radial-gradient(circle at 86% 22%, rgba(122,79,48,0.22) 0%, rgba(122,79,48,0) 42%),
                linear-gradient(180deg, #d4b494 0%, #c49a7d 52%, #b38969 100%) !important;
        }

        .landing-page .landing-hero {
            background: linear-gradient(180deg, #fdf3e8 0%, #f4e3d2 100%) !important;
            border-bottom: 1px solid rgba(165, 118, 73, 0.16) !important;
        }

        .landing-page #specialties {
            background:
                radial-gradient(circle at 8% 18%, rgba(255,224,191,0.16) 0%, rgba(255,224,191,0) 30%),
                radial-gradient(circle at 92% 82%, rgba(122,79,48,0.34) 0%, rgba(122,79,48,0) 42%),
                linear-gradient(165deg, #4f2f1f 0%, #3f2519 52%, #321d14 100%) !important;
            border-top: 1px solid rgba(255, 219, 184, 0.22) !important;
            border-bottom: 1px solid rgba(255, 219, 184, 0.22) !important;
        }

        .landing-page #specialties .section-kicker {
            color: #f3d4b3 !important;
        }

        .landing-page #specialties .section-heading h2 {
            color: #fff2e2 !important;
            text-shadow: 0 6px 18px rgba(0, 0, 0, 0.22);
        }

        .landing-page #specialties .section-heading p {
            color: rgba(255, 233, 212, 0.90) !important;
        }

        .landing-page #specialties .specialties-marquee {
            background: rgba(255, 246, 237, 0.08) !important;
            border-top: 1px solid rgba(255, 225, 193, 0.28) !important;
            border-bottom: 1px solid rgba(255, 225, 193, 0.28) !important;
            border-radius: 24px;
            box-shadow: inset 0 0 0 1px rgba(255, 216, 180, 0.14);
        }

        .landing-page #specialties .specialties-marquee::before {
            background: linear-gradient(90deg, rgba(63, 37, 25, 0.95) 0%, transparent 100%) !important;
        }

        .landing-page #specialties .specialties-marquee::after {
            background: linear-gradient(90deg, transparent 0%, rgba(63, 37, 25, 0.95) 100%) !important;
        }

        .landing-page #highlights {
            background:
                radial-gradient(circle at 10% 18%, rgba(255, 220, 190, 0.14) 0%, rgba(255, 220, 190, 0) 34%),
                radial-gradient(circle at 88% 84%, rgba(138, 90, 56, 0.28) 0%, rgba(138, 90, 56, 0) 44%),
                linear-gradient(165deg, #4a2d1d 0%, #3a2418 52%, #2c1a12 100%) !important;
            border-radius: 48px !important;
            box-shadow:
                inset 0 0 0 1px rgba(255, 225, 198, 0.16),
                0 24px 52px rgba(39, 22, 15, 0.24) !important;
        }

        .landing-page #highlights .highlight-panel {
            background: linear-gradient(180deg, #fffaf5 0%, #fff0e4 100%) !important;
            border: 2px solid rgba(182, 106, 60, 0.16) !important;
            border-radius: 36px !important;
            box-shadow: 0 22px 56px rgba(91, 52, 33, 0.08) !important;
        }

        .landing-page #highlights .highlight-preview {
            background: #fffdf9 !important;
            border: 1px solid rgba(182, 106, 60, 0.14) !important;
            border-radius: 28px !important;
            box-shadow: 0 12px 30px rgba(91, 52, 33, 0.06) !important;
        }

        .landing-page #highlights .highlight-preview-author {
            display: flex;
            flex-direction: column;
            gap: 0.2rem;
            margin-top: 1rem;
            padding: 0.95rem 1rem;
            background: #f8ece1;
            border: 1px solid rgba(182, 106, 60, 0.12);
            border-radius: 18px;
        }

        .landing-page #highlights .highlight-stat {
            background: #fff8f1 !important;
            border: 1px solid rgba(182, 106, 60, 0.14) !important;
            border-radius: 24px !important;
            box-shadow: 0 12px 26px rgba(91, 52, 33, 0.06) !important;
        }

        .landing-page #highlights .testimonial-block {
            background: var(--testimonial-shell-bg, #fff7f0) !important;
            border: 4px solid var(--testimonial-shell-border, #d19a6a) !important;
            border-radius: 30px !important;
            padding: 1.1rem !important;
            box-shadow: 0 26px 58px rgba(91, 52, 33, 0.12) !important;
            position: relative;
            overflow: hidden;
            min-height: 0;
        }

        .landing-page #highlights .testimonial-block::before {
            content: '';
            position: absolute;
            top: 0.9rem;
            bottom: 0.9rem;
            left: 0.9rem;
            width: 0.8rem;
            border-radius: 999px;
            background: var(--testimonial-accent, #b66a3c) !important;
        }

        .landing-page #highlights .testimonial-block::after {
            content: '';
            position: absolute;
            right: 1.2rem;
            bottom: 1.2rem;
            width: 4.25rem;
            height: 4.25rem;
            border-radius: 50%;
            background: var(--testimonial-accent-soft, rgba(182, 106, 60, 0.14)) !important;
        }

        .landing-page #highlights .testimonial-card {
            background: #111111 !important;
            border: 2px solid rgba(255, 255, 255, 0.14) !important;
            border-left: 10px solid var(--testimonial-accent, #b66a3c) !important;
            border-radius: 24px !important;
            padding: 1.6rem 1.35rem 1.4rem 1.5rem !important;
            box-shadow: 0 18px 34px rgba(0, 0, 0, 0.28) !important;
            opacity: 1 !important;
        }

        .landing-page #highlights .testimonial-card:hover,
        .landing-page #highlights .testimonial-card.is-active {
            border-color: rgba(255, 255, 255, 0.18) !important;
            border-left-color: var(--testimonial-accent, #b66a3c) !important;
            box-shadow: 0 22px 40px rgba(0, 0, 0, 0.34) !important;
        }

        .landing-page #highlights .testimonial-card p {
            color: #f5efe8 !important;
        }

        .landing-page #highlights .testimonial-stars {
            color: var(--testimonial-accent, #b66a3c) !important;
            background: rgba(255, 255, 255, 0.06) !important;
            border-radius: 999px !important;
            padding: 0.55rem 0.8rem !important;
            width: fit-content !important;
        }

        .landing-page #highlights .testimonial-author {
            display: flex !important;
            align-items: center !important;
            gap: 0.9rem !important;
            margin-top: 1.2rem !important;
            padding: 0.95rem !important;
            background: rgba(255, 255, 255, 0.05) !important;
            border-top: 1px solid rgba(255, 255, 255, 0.14) !important;
            border-radius: 18px !important;
        }

        .landing-page #highlights .testimonial-author > div:last-child {
            flex: 1;
            padding: 0.45rem 0.2rem;
            border-radius: 14px;
        }

        .landing-page #highlights .testimonial-author strong {
            color: #ffffff !important;
        }

        .landing-page #highlights .testimonial-author small {
            color: rgba(255, 255, 255, 0.72) !important;
        }

        .landing-page #highlights .testimonial-author .author-avatar,
        .landing-page #highlights .author-avatar {
            border: 2px solid var(--testimonial-accent, #b66a3c) !important;
            background: var(--testimonial-accent, #b66a3c) !important;
            color: #ffffff !important;
        }

        .landing-page #highlights .author-avatar-dark {
            background: var(--testimonial-accent, #b66a3c) !important;
            color: #ffffff !important;
        }

        .landing-page #highlights .cta-banner {
            background: linear-gradient(180deg, #fffaf5 0%, #ffefe1 100%) !important;
            border: 2px solid rgba(182, 106, 60, 0.14) !important;
            border-radius: 38px !important;
            box-shadow: 0 28px 70px rgba(91, 52, 33, 0.1) !important;
        }

        .landing-page #highlights .visit-card {
            border-radius: 24px !important;
            border: 1px solid rgba(182, 106, 60, 0.14) !important;
            box-shadow: 0 14px 28px rgba(91, 52, 33, 0.08) !important;
        }

        @media (max-width: 576px) {
            .landing-page #highlights .testimonial-block {
                padding: 0.9rem !important;
                border-radius: 28px !important;
            }

            .landing-page #highlights .testimonial-card {
                padding: 1.3rem 1rem 1.2rem 1.15rem !important;
                border-left-width: 8px !important;
                border-radius: 20px !important;
            }
        }
    </style>
{% endblock %}

{% block body %}
<div class="landing-page">
    <section class="landing-hero landing-section" id="hero">
        <div class="container">
            <div class="row align-items-center g-5">
                <div class="col-lg-6">
                    <p class="landing-kicker">Premium Bakery</p>
                    <h1 class="landing-title fw-bold mb-3">Baked with heart, served with soul.</h1>
                    <p class="landing-lead mb-4">
                        Discover artisan breads, delicate pastries, and celebration cakes crafted fresh every day for the moments that matter.
                    </p>

                    <div class="landing-actions mb-4">
                        <a href="{{ path('app_menu') }}" class="btn btn-landing-primary"> Menu</a>
                        <a href="{{ path('custom_cake_builder') }}" class="btn btn-landing-secondary">Build Your Cake</a>
                        {% if not app.user %}
                            <a href="{{ path('app_login') }}" class="btn btn-landing-secondary">Sign In</a>
                        {% endif %}
                    </div>

                    <div class="landing-metrics">
                        <div class="landing-metric">
                            <strong>24h</strong>
                            <span>Slow-fermented</span>
                        </div>
                        <div class="landing-metric">
                            <strong>50k+</strong>
                            <span>Treats delivered</span>
                        </div>
                        <div class="landing-metric">
                            <strong>4.9 star</strong>
                            <span>Guest rating</span>
                        </div>
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="hero-visual">
                        <div class="hero-glow"></div>
                        <div class="hero-frame shadow-sm">
                            <img src="{{ asset('image/bakery-transparent.png') }}" alt="Sweetoria bakery showcase" class="hero-image img-fluid">
                        </div>
                       
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="landing-section section-soft py-5" id="specialties" style="background:linear-gradient(165deg,#4f2f1f 0%,#3f2519 52%,#321d14 100%);">
        <div class="container py-4 py-lg-5">
            <div class="section-heading text-center mx-auto mb-5">
                <p class="section-kicker mb-2">Specialties</p>
                <h2 class="display-5 fw-bold mb-3">Quick to scan, easy to choose</h2>
                <p class="mb-0">
                    Browse the bakery in clear, friendly categories so visitors can find what they want without feeling overwhelmed.
                </p>
            </div>

            {% set specialties = [
                {'title': 'Breakfast Bakes', 'desc': 'Warm pastries and morning picks for an easy start.', 'image': 'breakfast.jpg', 'icon': 'bi-cup-hot'},
                {'title': 'Custom Cakes', 'desc': 'Beautiful layers for birthdays, anniversaries, and gifts.', 'image': 'cakes.jpg', 'icon': 'bi-cake2'},
                {'title': 'Dessert Boxes', 'desc': 'Sweet assortments for sharing, gifting, or snacking.', 'image': 'dessert.jpg', 'icon': 'bi-gift'},
                {'title': 'Lunch Treats', 'desc': 'Savory bakes and comfort bites for midday cravings.', 'image': 'lunch.jpg', 'icon': 'bi-basket'}
            ] %}

            <div class="gallery-marquee specialties-marquee" aria-label="Sweetoria specialties showcase">
                <div class="gallery-marquee-track specialties-marquee-track">
                    {% for loopIndex in 1..2 %}
                        <div class="gallery-marquee-group specialties-marquee-group" {% if loopIndex > 1 %}aria-hidden="true"{% endif %}>
                            {% for item in specialties %}
                                <article class="info-card">
                                    <div class="info-card-image">
                                        <img src="{{ asset('image/' ~ item.image) }}" alt="{{ item.title }}">
                                    </div>
                                    <div class="info-card-body">
                                        <div class="info-card-icon">
                                            <i class="bi {{ item.icon }}"></i>
                                        </div>
                                        <h3 class="h4 fw-bold mb-2">{{ item.title }}</h3>
                                        <p class="mb-0">{{ item.desc }}</p>
                                    </div>
                                </article>
                            {% endfor %}
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </section>

    <section class="landing-section py-5" id="gallery">
        <div class="container py-4 py-lg-5">
            <div class="section-heading text-center mx-auto mb-5">
                <p class="section-kicker mb-2">Gallery</p>
                <h2 class="display-5 fw-bold mb-3">Beautiful bakes, easy to browse</h2>
                <p class="mb-0">
                    Keep the menu visually inviting with image-led cards that guide the eye from one item to the next.
                </p>
            </div>

            {% set gallery = [
                {'image': 'new1.jpg', 'title': 'Fresh Bread Selection', 'text': 'Soft, fragrant loaves baked daily.'},
                {'image': 'new2.jpg', 'title': 'Custom Cake Designs', 'text': 'Elegant cakes made for special moments.'},
                {'image': 'new3.jpg', 'title': 'Sweet Pastries', 'text': 'Treats with rich texture and gentle sweetness.'}
            ] %}

            <div class="gallery-marquee" aria-label="Sweetoria gallery showcase">
                <div class="gallery-marquee-track">
                    {% for loopIndex in 1..2 %}
                        <div class="gallery-marquee-group" {% if loopIndex > 1 %}aria-hidden="true"{% endif %}>
                            {% for item in gallery %}
                                <article class="gallery-card">
                                    <img src="{{ asset('image/' ~ item.image) }}" alt="{{ item.title }}" class="gallery-image">
                                    <div class="gallery-card-body">
                                        <h3 class="h5 fw-bold mb-2">{{ item.title }}</h3>
                                        <p class="mb-0">{{ item.text }}</p>
                                    </div>
                                </article>
                            {% endfor %}
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </section>

    <section class="landing-section section-soft py-5 story-section" id="story">
        <div class="container-fluid px-0 position-relative">
            <div class="story-background-overlay"></div>
            <div class="story-panel p-4 p-lg-5 rounded-4 mx-auto">
                        <p class="section-kicker mb-2">Our Story</p>
                        <h2 class="display-5 fw-bold mb-4">A tradition of sweetness passed through generations.</h2>
                    <p class="landing-copy mb-4">
                        Each recipe is designed to feel comforting, celebratory, and easy to choose from. We keep the experience warm and approachable.
                    </p>

                    <div class="story-grid">
                        <div class="story-pill">
                            <strong>Fresh daily menu</strong>
                            <span>Prepared with care, consistency, and presentation in mind.</span>
                        </div>
                        <div class="story-pill">
                            <strong>Balanced flavors</strong>
                            <span>Designed to be satisfying without feeling heavy.</span>
                        </div>
                        <div class="story-pill">
                            <strong>Easy ordering</strong>
                            <span>Clear browsing and a smooth shopping path for guests.</span>
                        </div>
                        <div class="story-pill">
                            <strong>Warm service</strong>
                            <span>Friendly support that keeps the bakery feeling personal.</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="story-corner-image">
                <img src="{{ asset('image/cakes.jpg') }}" alt="Elegant pastry detail" class="img-fluid rounded-4">
            </div>
        </div>
    </section>

    <section class="landing-section py-5" id="highlights" style="background:
        radial-gradient(circle at 10% 18%, rgba(255,220,190,0.16) 0%, rgba(255,220,190,0) 34%),
